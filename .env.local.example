# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Temporary admin bypass — protects /admin until real auth ships
ADMIN_PASSWORD=

# Anthropic — used by the /api/webhook/[botId] route
ANTHROPIC_API_KEY=

# Groq — Whisper transcription for WhatsApp voice messages
GROQ_API_KEY=

# Kalyo — activate-pro-trial tool target (separate Supabase project).
# Only used when a message arrives for the bot whose id equals KALYO_BOT_ID.
KALYO_SUPABASE_URL=
KALYO_SUPABASE_SERVICE_KEY=
KALYO_BOT_ID=
# WhatsApp destination for the notify_sales_team tool (full E.164 or whatsapp:+… form).
KALYO_SALES_PHONE=

# Shared secret for Vercel cron authentication.
# Cron routes require "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# Optional Twilio Content Template (twilio/quick-reply) for native WhatsApp buttons
# on the first Kalyo reply. Without this, numbered text options are appended instead.
KALYO_QUICK_REPLY_CONTENT_SID=

# Meta (Facebook Messenger / Instagram) webhook.
# META_VERIFY_TOKEN is a random string you pick — Meta echoes it during the
# webhook subscribe handshake. META_PAGE_ACCESS_TOKEN is the Page access
# token used to send outbound messages via the Graph API.
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
