# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Temporary admin bypass — protects /admin until real auth ships
ADMIN_PASSWORD=

# Anthropic — used by the /api/webhook/[botId] route
ANTHROPIC_API_KEY=

# Groq — Whisper transcription for WhatsApp voice messages
GROQ_API_KEY=

# Kalyo — activate-pro-trial tool target (separate Supabase project).
# Only used when a message arrives for the bot whose id equals KALYO_BOT_ID.
KALYO_SUPABASE_URL=
KALYO_SUPABASE_SERVICE_KEY=
KALYO_BOT_ID=
# Public Telegram bot for psychologists (Sprint 5.2). Optional until configured.
KALYO_PUBLIC_BOT_TOKEN=
# WhatsApp destination for the notify_sales_team tool (full E.164 or whatsapp:+… form).
KALYO_SALES_PHONE=

# Shared secret for Vercel cron authentication.
# Cron routes require "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# Optional Twilio Content Template (twilio/quick-reply) for native WhatsApp buttons
# on the first Kalyo reply. Without this, numbered text options are appended instead.
KALYO_QUICK_REPLY_CONTENT_SID=

# Twilio WhatsApp Content Template for trial welcome message (kalyo_welcome_trial, es_MX).
# Must be approved by Meta before use in production.
KALYO_WELCOME_TEMPLATE_SID=

# Meta (Facebook Messenger / Instagram) webhook.
# META_VERIFY_TOKEN is a random string you pick — Meta echoes it during the
# webhook subscribe handshake. META_PAGE_ACCESS_TOKEN is the Page access
# token used to send outbound messages via the Graph API.
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=

# ── KPI dashboard ─────────────────────────────────────────────────────────────

# Google Analytics 4 — service account JSON as a single-line string.
# Vercel (required): paste the minified JSON from google-credentials.json:
#   cat google-credentials.json | jq -c . | pbcopy
# Local fallback: set GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json instead.
GOOGLE_CREDENTIALS_JSON=
GA4_LANDING_PROPERTY_ID=531207061
GA4_APP_PROPERTY_ID=539858946

# Meta Graph API (Ads + Instagram insights). META_ACCESS_TOKEN can alias META_PAGE_ACCESS_TOKEN.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_1105914435027314
META_INSTAGRAM_ACCOUNT_ID=17841445123022718
META_BUSINESS_ID=1831681224187619

# Twilio message metrics sync
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Kalyo Supabase (MRR sync) — same project as KALYO_SUPABASE_* above if shared.
# KALYO_SUPABASE_URL and KALYO_SUPABASE_SERVICE_KEY are reused by kalyo-sync cron.
